<?xml version="1.0"?>
<ruleset name="WooFlux">
	<description>WooFlux coding standards — WordPress standard with project-specific exclusions.</description>

	<!-- Files to scan -->
	<file>includes/</file>
	<file>templates/</file>
	<file>wooflux.php</file>
	<file>uninstall.php</file>

	<!-- Base standard -->
	<rule ref="WordPress"/>

	<!-- manage_woocommerce is a built-in WooCommerce capability -->
	<rule ref="WordPress.WP.Capabilities">
		<properties>
			<property name="custom_capabilities" type="array">
				<element value="manage_woocommerce"/>
			</property>
		</properties>
	</rule>

	<!-- Minimum supported PHP -->
	<config name="minimum_supported_wp_version" value="6.5"/>
	<config name="testVersion" value="8.0-"/>
</ruleset>
