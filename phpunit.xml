			<file>tests/php/TestWooFluxQuery.php</file>
			<file>tests/php/TestWooFluxREST.php</file>
		</testsuite>
	</testsuites>

	<source>
		<include>
			<directory suffix=".php">includes</directory>
		</include>
	</source>
</phpunit>
